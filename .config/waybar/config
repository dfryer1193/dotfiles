{
    "layer": "top",
    "position": "top",
    "spacing": 4,
    "modules-left": ["sway/workspaces", "sway/scratchpad"],
    "modules-center": ["sway/window"],
    "modules-right": ["custom/weather", "custom/packages", "disk", "temperature", "memory", "pulseaudio", "clock", "network", "battery", "custom/audio_idle_inhibitor", "tray"],
     "sway/workspaces": {
         "disable-scroll": true,
         "all-outputs": false,
         "warp-on-scroll": false,
         "format": "{name}: {icon}",
         "format-icons": {
             "urgent": "´ü¬",
             "focused": "´åÆ",
             "default": "´äæ"
         }
     },
    "tray": {
      "show-passive-items": true
    },
    "custom/weather": {
        "interval": 3600,
        "exec": "curl \"https://wttr.in/?format=%c%t\""
    },
    "disk": {
        "format": "¾░ïè {free}",
        "path": "/"
    },
    "custom/packages": {
        "interval": 3600,
        "exec": "~/.bin/yayupdates | wc -l",
        "format": "\uf077  {}"
    },
    "temperature": {
        "hwmon-path": "/sys/class/hwmon/hwmon4/temp1_input",
        "critical-threshold": 80,
        "format-critical": "{icon} {temperatureC}┬░C",
        "format": "{icon} {temperatureC}┬░C",
        "format-icons": ["´Ø½", "´ïë", "´Ø®"]
    },
    "memory": {
        "format": "¯┐à {percentage}%",
        "tooltip-format": "{used}GiB / {avail}GiB"
    },
    "wireplumber": {
	"format": "{icon} {volume}%",
	"format-muted": "¯╗¿ MUTE",
	"on-click": "amixer set Master toggle",
        "format-icons": ["´ÇĞ", "´Çğ", "´Ç¿"]
    },
    "pulseaudio": {
        "scroll-step": 5,
        "format": "{icon} {volume}%",
        "format-bluetooth": "{volume}% {icon}´èö {format_source}",
        "format-bluetooth-muted": "¯╗¿ {icon}´èö {format_source}",
	"format-muted": "¯╗¿ MUTE",
        "format-icons": {
            "headphone": "´ÇÑ",
            "hands-free": "´ûÉ",
            "headset": "´ûÉ",
            "phone": "´éò",
            "portable": "´éò",
            "car": "´å╣",
            "default": ["´ÇĞ", "´Çğ", "´Ç¿"]
        },
        "on-click": "amixer set Master toggle"
    },
    "custom/media": {
        "format": "{icon} {text}",
        "return-type": "json",
        "max-length": 25,
        "format-icons": {
            "spotify": "´å╝",
            "default": "¾░ØÜ"
        },
        "escape": true,
        "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null",
        "on-click": "playerctl play-pause",
        "on-scroll-down": "playerctl next",
        "on-scroll-up": "playerctl previous"
    },
    "clock": {
        "timezone": "America/New_York",
        "interval": 1,
        "format": "´Çù {:%a %b %d %H.%M}"
    },
    "network": {
        "format-wifi": "{essid} ({signalStrength}%) ´ç½ ",
        "format-ethernet": "{bandwidthUpBytes} \uf6ff",
        "tooltip-format": "{ifname} via {gwaddr} \uf6ff",
        "format-linked": "{ifname} (No IP) \uf6ff",
        "format-disconnected": "Disconnected ÔÜá",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "battery": {
	    "bat": "BAT0",
	    "adapter": "AC",
	    "format": "{icon} {capacity}%",
	    "format-charging": "¾░éä {capacity}%",
	    "format-icons": ["¾░éÄ", "¾░ü║", "¾░ü╗", "¾░ü╝", "¾░ü¢", "¾░ü¥", "¾░ü┐", "¾░éÇ", "¾░éü", "¾░ü╣"]
    },
    "custom/audio_idle_inhibitor": {
		"format": "{icon}",
		"exec": "sway-audio-idle-inhibit --dry-print-both-waybar",
		"exec-if": "which sway-audio-idle-inhibit",
		"return-type": "json",
		"format-icons": {
			"output": "´àä ",
			"input": "´ä░ ",
